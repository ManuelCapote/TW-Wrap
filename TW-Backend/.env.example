# Server Configuration
PORT=3000
NODE_ENV=development

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=24h

# Database Configuration (for future use)
DATABASE_URL=postgresql://user:password@localhost:5432/tw_web

# CORS Configuration
FRONTEND_URL=http://localhost:5174

# Security
BCRYPT_ROUNDS=12

# Email Service Configuration
# For development: Use Mailhog (localhost:1025) or leave blank for console logging
# For production: Configure SMTP settings below
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@tw-web.com
EMAIL_FROM_NAME=TW-Web

# Password Reset Configuration
# Token expiration in milliseconds (default: 30 minutes)
RESET_TOKEN_EXPIRY=1800000